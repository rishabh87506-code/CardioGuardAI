# ─────────────────────────────────────────────────────────────────────────────
# CardioGuard AI — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.env
**/.env
**/.env.local
*.pem
*.key
service-account.json
firebase-adminsdk*.json

# ── Build Artifacts ──────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/

# ── IDE & OS ─────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Testing & Coverage ───────────────────────────────────────────────────────
coverage/
.coverage
.pytest_cache/
htmlcov/
.nyc_output/
junit.xml

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.out
*.tmp

# ── Database ─────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Archives ─────────────────────────────────────────────────────────────────
*.zip

# ── ML Models (large binaries — store in object storage for production) ───────
# Uncomment to exclude model artifacts from git
# *.pkl
