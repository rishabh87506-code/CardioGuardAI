# ─────────────────────────────────────────────────────────────────────────────
# CardioGuard AI — Environment Configuration Example
# Copy this file to .env and fill in your values before running locally.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Gateway (Node.js) ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# JWT secret — use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=your-secret-key-change-in-production

# Internal URL of the Python Wellness Engine (service name in docker-compose)
PYTHON_BACKEND_URL=http://wellness-engine:8000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=cardioguard
PG_USER=cardioguard_user
PG_PASSWORD=change-me

# Full connection string (used by api-gateway/config/db.js)
DATABASE_URL=postgresql://cardioguard_user:change-me@postgres:5432/cardioguard

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=           # Uncomment and set if Redis auth is enabled

# ── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=cardioguard
INFLUXDB_BUCKET=wellness_metrics
INFLUXDB_TOKEN=your-token
# Used during InfluxDB first-run setup
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-influx
INFLUXDB_ADMIN_TOKEN=your-token

# ── Python Wellness Engine ───────────────────────────────────────────────────
PYTHON_ENV=development

# ── Optional Integrations ────────────────────────────────────────────────────
# WHATSAPP_API_KEY=          # Meta Cloud API key for WhatsApp broadcasts
# ANTHROPIC_API_KEY=         # Claude API key for AI wellness guidance
# GOOGLE_CLOUD_PROJECT=      # GCP project ID (if using Firestore fallback)
